# ---- Core ----
NODE_ENV=development
PORT=8000
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?schema=public"

# Comma-separated list of allowed origins for CORS.
CORS_ORIGIN=http://localhost:3000

# Public URL used in outgoing emails (verify, reset, etc).
FRONTEND_URL=http://localhost:3000

# ---- Auth ----
JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRES_IN=3600s

# Skip EmailVerifiedGuard in non-production for local dev.
# Hard-locked off in production regardless of value.
DEV_BYPASS_EMAIL_VERIFICATION=false

# ---- Mail (Nodemailer SMTP) ----
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# ---- Money / pricing (Int rupiah) ----
# Commission percent floor-applied at payment upload.
PLATFORM_COMMISSION_PCT=20
# Minimum payout amount tutor can request.
MIN_PAYOUT_RUPIAH=50000
# Per-day price for featured listing boost.
FEATURED_PRICE_PER_DAY=5000
# Subscription tier monthly prices.
PRICE_PREMIUM_STUDENT=50000
PRICE_PRO_TUTOR=100000

# ---- Referral rewards (Int rupiah) ----
# Granted on referred student's first confirmed session payment.
REFERRAL_REWARD_REFERRER_RUPIAH=25000
REFERRAL_REWARD_REFERRED_RUPIAH=25000

# ---- Object storage (S3 / MinIO) ----
# Required. App refuses to boot if any is missing. Public asset proxy
# streams from this store at /uploads/<key>.
# Local: MinIO at :9000 with bucket "dbbconnect".
# Prod: AWS S3 -> set endpoint to https://s3.<region>.amazonaws.com,
#       leave S3_FORCE_PATH_STYLE=false.
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=dbbconnect
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
